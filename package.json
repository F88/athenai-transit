{
  "name": "athenai-transit",
  "private": true,
  "version": "2026.03.16",
  "description": "'Athenai Transit' is a web application that helps users explore transit options without specifying a destination.",
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "gtfs",
    "gtfs-jp",
    "transit",
    "bus",
    "typescript",
    "nodejs"
  ],
  "author": "F88 <685250+F88@users.noreply.github.com>",
  "homepage": "https://github.com/F88/athenai-transit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/F88/athenai-transit.git"
  },
  "bugs": {
    "url": "https://github.com/F88/athenai-transit/issues"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "preview": "vite preview",
    "data:sync": "npx tsx scripts/copy-pipeline-data.ts",
    "pipeline:download:gtfs": "npx tsx --env-file-if-exists=pipeline/.env.pipeline.local pipeline/scripts/download-gtfs.ts --targets pipeline/targets/download-gtfs.ts",
    "pipeline:download:odpt-json": "npx tsx --env-file-if-exists=pipeline/.env.pipeline.local pipeline/scripts/download-odpt-json.ts --targets pipeline/targets/download-odpt-json.ts",
    "pipeline:build:db": "npx tsx pipeline/scripts/build-gtfs-db.ts --targets pipeline/targets/build-db.ts",
    "pipeline:build:json": "npx tsx pipeline/scripts/app-data/build-app-data-from-gtfs.ts --targets pipeline/targets/build-json.ts",
    "pipeline:build:odpt-train": "npx tsx pipeline/scripts/app-data/build-app-data-from-odpt-train.ts --targets pipeline/targets/build-odpt-train.ts",
    "pipeline:build:shapes:gtfs": "npx tsx pipeline/scripts/app-data/build-route-shapes-from-gtfs.ts --targets pipeline/targets/build-shapes-gtfs.ts",
    "pipeline:build:shapes:ksj": "npx tsx pipeline/scripts/app-data/build-route-shapes-from-ksj-railway.ts --targets pipeline/targets/build-shapes-ksj.ts",
    "pipeline:validate": "npx tsx pipeline/scripts/app-data/validate-app-data.ts",
    "pipeline:check:odpt-resources": "npx tsx pipeline/scripts/analysis/check-odpt-resources.ts",
    "pipeline:describe": "npx tsx pipeline/scripts/analysis/describe-resources.ts",
    "pipeline:dev-tools": "npx tsx pipeline/scripts/dev-tools.ts",
    "cleanup:vercel": "node ops/cleanup-vercel-deployments.mjs --dry-run",
    "cleanup:vercel:run": "node ops/cleanup-vercel-deployments.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@holiday-jp/holiday_jp": "^2.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.0.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "storybook": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "eslint-plugin-storybook": "^10.2.17",
    "playwright": "^1.58.2",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18"
  }
}
